   "outputs": [],
   "source": [
    "def bubble_sort(arr):\n",
    "    for i in range(len(arr)):\n",
    "        for j in range(len(arr)-i-1):\n",
    "            if arr[j] > arr[j+1]:\n",
    "                arr[j],arr[j+1] = arr[j+1],arr[j]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "7ef91238",
   "metadata": {},
   "outputs": [],
   "source": [
    "arr = [9,2,5,7,8]\n",
    "bubble_sort(arr)"
   ]
  },
